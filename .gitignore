out/
outputs/
# Maven
target/
*.jar
*.war
*.ear
*.class
.mvn/wrapper/maven-wrapper.jar

# Gradle (in case any module switches)
build/
.gradle/

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/
.factorypath

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs + runtime state
*.log
# Note: bare `logs/` pattern removed 2026-05-19 — it incorrectly caught the
# `docs/logs/` archive partition (which MUST be tracked: rule-migration-map.yaml,
# governance-waves.md, migration-coverage-report.md, etc. per ADR-0086). Only
# directory we'd want to ignore here was `third_party/*/logs/`, already covered
# by `third_party/` below.
var/
state/
state-dir/
*.pid

# Environment + secrets — NEVER commit
.env
.env.local
.env.*.local

# Generated architecture artefacts (ADR-0068 / CLAUDE.md Rule 34).
# docs/governance/architecture-graph.yaml and its Mermaid sibling are emitted by
# gate/build_architecture_graph.py from authoritative YAML inputs. They MUST NOT
# be hand-edited. Tracking them would let merge conflicts and accidental edits
# silently violate Rule 34's "must be generated, never hand-edited" clause.
# Consumers (LLMs, contributors, CI) regenerate on demand; Rule 42 enforces
# byte-identical idempotency.
docs/governance/architecture-graph.yaml
docs/governance/architecture-graph.mmd
# Workspace projection (ADR-0147 W4); same rationale — regenerated by
# tools/architecture-workspace + bash gate/check_architecture_workspace.sh.
docs/governance/architecture-workspace-graph.yaml
*.pem
*.key
*.crt
secrets/

# Spring Boot
application-local.yaml
application-local.yml
application-local.properties

# Test artifacts
*.lcov
coverage/
.nyc_output/

# Python sidecar (when adopted)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Tier C: local source clones (gitignored; SHAs tracked in third_party/MANIFEST.md)
third_party/*/
third_party/**/

# Architecture artifacts
docs/delivery/*.json
docs/verification/*.json
!docs/delivery/.gitkeep
!docs/delivery/*.log
!docs/verification/.gitkeep

# Gate logs:
#   - gate/log/<sha>.json     — delivery-valid evidence; tracked (committed by maintainer)
#   - gate/log/local/         — local-only / failed / dirty-tree / fail-closed runs;
#                               NEVER tracked, never delivery evidence (cycle-4 sec-A3)
gate/log/local/

# Gate run logs (per-run NDJSON; gitignored per token-optimization wave PR-E1)
gate/log/runs/
gate/log/latest
.commit-msg-tmp

# CodeGraph: local SQLite index (regenerated by `codegraph init -i` / `sync`)
# and any node_modules under tools/codegraph (re-installed by `npm ci`;
# package.json + package-lock.json are tracked so the team pins the version).
.codegraph/
node_modules/

# Local editor / agent runtime state — never committed.
.codex/
.claude/
.obsidian/
tmp/

# --- Harness ToolKit (merged 2026-07-02 from /tmp/HarnessToolKit_Test) ---
